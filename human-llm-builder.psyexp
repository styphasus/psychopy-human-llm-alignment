    <LoopInitiator loopType="TrialHandler" name="ScenarioLoop">
      <Param name="Selected rows" updates="None" val="" valType="str"/>
      <Param name="conditions" updates="None" val="[{'scenario': 'You need to run a few errands downtown which you think \nmay take you an hour. You go to your manager’s office at \nwork with whom you get on well and ask him to cover for \nyou. What do you say to him?', 'Alignment': 'high'}, {'scenario': 'You invited friends for a cozy dinner. At the end, one says: “It was a nice evening!” You answer:', 'Alignment': 'medium'}, {'scenario': 'You are on your first day of the new semester and you found yourself lost on your way to the meeting room at the new Administration Building. You are unsure of the location of the exact meeting room. You want to ask for the location from a classmate you just met. You say:', 'Alignment': 'low'}, {'scenario': &quot;You just met a new friend online; he invites you and some of your other friends to his new house tomorrow for lunch. You can't attend as you are required to accompany your parents to the hospital. You refuse by saying?&quot;, 'Alignment': 'high'}, {'scenario': 'You are a graduate student preparing for a conference presentation. You realize that you left your USB stick with your slides at home. One of your classmates lives near your house. You call him to ask if he can go by and bring it to you. What do you say to him?', 'Alignment': 'medium'}, {'scenario': 'You have been working on a shared project with a colleague. You notice that an important report needs to be submitted today, but you have to leave early for a medical appointment. You go to your colleague’s desk and ask him to send it in on your behalf. What do you say to him?', 'Alignment': 'low'}, {'scenario': 'You are organizing a farewell party for a close colleague. You need some decorations from the supply room, but it’s locked. You see the janitor passing by with the keys. You go to him and ask to open the door for you. What do you say to him?', 'Alignment': 'high'}, {'scenario': 'You are in a train heading to an important meeting. You realize that you have forgotten your phone charger. The passenger sitting next to you has the same type of phone. You turn to him and ask to borrow his charger for a few minutes. What do you say to him?', 'Alignment': 'medium'}, {'scenario': 'You are visiting a museum with a friend. You realize that you left your wallet at home and need to pay the entry fee. You ask your friend if he could cover the ticket for you. What do you say to him?', 'Alignment': 'low'}, {'scenario': 'You are in a supermarket and cannot reach a box on a high shelf. A tall shopper stands next to you. You ask him to help you get the box. What do you say to him?', 'Alignment': 'high'}, {'scenario': 'You are at work and need to send an urgent email. Your computer suddenly stops working. You go to your coworker’s desk and ask to use his computer. What do you say to him?', 'Alignment': 'medium'}, {'scenario': 'You are sitting in a café, and your phone battery is almost dead. A friend sitting with you has a charger. You ask her if you can use it for a few minutes. What do you say to her?', 'Alignment': 'low'}, {'scenario': 'You are studying in the library and need a pen. You see someone at the next table with several pens. You ask to borrow one. What do you say to him?', 'Alignment': 'high'}, {'scenario': 'You are studying in the library and need a charger. You see another student with the same laptop. You ask if you can borrow it for a few minutes. What do you say to him?', 'Alignment': 'medium'}, {'scenario': 'You are at the airport and cannot find your boarding gate. You ask a security officer for directions. What do you say to him?', 'Alignment': 'low'}, {'scenario': 'You are working late at the office. You need to print a document but the printer is out of paper. You go to your colleague’s desk and ask for some. What do you say to him?', 'Alignment': 'high'}, {'scenario': 'You are preparing a presentation with a friend. He has the USB drive with your slides. You ask him to send the file to you. What do you say to him?', 'Alignment': 'medium'}, {'scenario': 'You are at work and need to borrow a stapler. You go to your colleague’s desk. What do you say to him?', 'Alignment': 'low'}, {'scenario': 'You are studying in class and forget your pen. You ask the student next to you to borrow one. What do you say to him?', 'Alignment': 'high'}, {'scenario': 'You are at a friend’s house and want to use the Wi-Fi. You ask for the password. What do you say to him?', 'Alignment': 'medium'}, {'scenario': 'You are preparing for an important client meeting at work, but your printer suddenly runs out of ink. You go to a coworker’s desk to ask if you can use theirs for a few pages. What do you say?', 'Alignment': 'low'}, {'scenario': 'You are at the airport, and the airline staff announces a gate change. You’re unsure where the new gate is and need to ask for directions politely. What do you say?', 'Alignment': 'high'}, {'scenario': 'You are invited to a friend’s housewarming party but realize you already have a family commitment that evening. You want to decline the invitation politely. What do you say?', 'Alignment': 'medium'}, {'scenario': 'You are sitting in a café with your laptop, but the Wi-Fi connection is not working. You approach the cashier to ask if there’s another network you can use. What do you say?', 'Alignment': 'low'}, {'scenario': 'You are on a video call and your microphone stops working. You fix it after a few moments and want to apologize to the group for the delay. What do you say?', 'Alignment': 'high'}, {'scenario': 'You are at a busy café and accidentally take someone else’s order from the counter. When they approach you, you realize the mistake and want to apologize. What do you say?', 'Alignment': 'medium'}, {'scenario': 'You are visiting your friend’s new apartment for the first time. You want to compliment their decoration and make them feel appreciated. What do you say?', 'Alignment': 'low'}, {'scenario': 'You are watching a movie in the theater and someone near you is talking loudly. You want to ask them to lower their voice politely. What do you say?', 'Alignment': 'high'}, {'scenario': 'You are in a meeting and someone gives you a compliment on your presentation. You want to respond humbly and thank them. What do you say?', 'Alignment': 'medium'}, {'scenario': 'You are in a clothing store and want to know if an item is available in a different size. You ask the sales assistant. What do you say?', 'Alignment': 'low'}, {'scenario': 'You are at a family gathering and accidentally drop a plate of food. You want to apologize and offer to clean it up. What do you say?', 'Alignment': 'high'}, {'scenario': 'You are attending a friend’s birthday party and want to compliment the cake they baked themselves. What do you say?', 'Alignment': 'medium'}, {'scenario': 'You are on a bus and notice that an elderly person has boarded without a seat available. You decide to offer yours. What do you say?', 'Alignment': 'low'}, {'scenario': 'You are walking in the park and someone’s dog approaches you playfully. The owner apologizes and you want to respond kindly. What do you say?', 'Alignment': 'high'}, {'scenario': 'You are checking out at a grocery store and realize you left your shopping bag in the car. You tell the cashier you’ll be right back. What do you say?', 'Alignment': 'medium'}, {'scenario': 'You are at the office and notice your colleague looks upset. You want to ask if everything is alright without prying. What do you say?', 'Alignment': 'low'}, {'scenario': 'You are at the gym and someone is using a machine you planned to use next. You ask how long they’ll need it. What do you say?', 'Alignment': 'high'}, {'scenario': 'You are joining a virtual meeting where you don’t know most of the participants. You decide to briefly introduce yourself. What do you say?', 'Alignment': 'medium'}, {'scenario': 'You are visiting a new restaurant and really enjoy the food. You want to compliment the waiter and thank the chef. What do you say?', 'Alignment': 'low'}, {'scenario': 'You are at a conference and accidentally interrupt someone during their speech. You want to apologize and let them continue. What do you say?', 'Alignment': 'high'}, {'scenario': 'You are boarding a crowded bus and accidentally bump into another passenger. You want to apologize politely. What do you say?', 'Alignment': 'medium'}, {'scenario': 'You are meeting your friend at a café but arrive 15 minutes late. You want to apologize and explain. What do you say?', 'Alignment': 'low'}, {'scenario': 'You are at a bank and need to ask the teller how to open a new account. You approach the counter politely. What do you say?', 'Alignment': 'high'}, {'scenario': 'You are visiting a museum and drop your brochure. Someone picks it up and hands it back to you. You respond politely. What do you say?', 'Alignment': 'medium'}, {'scenario': 'You are at a networking event and someone introduces themselves to you. You want to respond and keep the conversation going. What do you say?', 'Alignment': 'low'}, {'scenario': 'You are at a friend’s dinner party and they serve a dish you’ve never tried before. You want to compliment it after tasting. What do you say?', 'Alignment': 'high'}, {'scenario': 'Your assignment is due tonight, but you haven´t finished it yet. You want to ask your lecturer for a 1 day extension. What do you say?', 'Alignment': 'medium'}, {'scenario': 'You don´t have a car and need help moving a few things from your apartment. You want to ask your best friend if he has time on Monday afternoon. What do you say to her?', 'Alignment': 'low'}, {'scenario': 'You´re driving with your mother to Frauenlobstraße 7a, but you get lost and want to ask a pedestrian for directions. What do you say to the pedastrian?', 'Alignment': 'high'}, {'scenario': 'You are in a shared office and your coworker is playing music out loud while you are trying to focus. You want to ask them politely to lower the volume. What do you say?', 'Alignment': 'medium'}]" valType="str"/>
      <Param name="conditionsFile" updates="None" val="scenarios.xlsx" valType="file"/>
      <Param name="endPoints" updates="None" val="[0, 1]" valType="num"/>
      <Param name="isTrials" updates="None" val="True" valType="bool"/>
      <Param name="loopType" updates="None" val="random" valType="str"/>
      <Param name="nReps" updates="None" val="1" valType="num"/>
      <Param name="name" updates="None" val="ScenarioLoop" valType="code"/>
      <Param name="random seed" updates="None" val="" valType="code"/>
    </LoopInitiator>
    <Routine name="TaskRoutine"/>
    <Routine name="PromptRoutine"/>
    <Routine name="WaitRoutine"/>
    <Routine name="AIRoutine"/>
    <Routine name="RatingRoutine"/>
    <Routine name="PauseRoutine"/>
    <LoopTerminator name="ScenarioLoop"/>
    <Routine name="eyelinkStopRecording_2"/>
    <Routine name="thanks"/>
  </Flow>
</PsychoPy2experiment>
