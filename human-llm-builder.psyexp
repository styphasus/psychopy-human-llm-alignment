        <Param val="import * as time from 'time';&amp;#10;psychoJS.experiment.addData(&quot;el_setup.started_Unix&quot;, time.time());&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="import time&amp;#10;thisExp.addData(&quot;el_setup.started_Unix&quot;, time.time())" valType="extendedCode" updates="constant" name="Begin Routine"/>
