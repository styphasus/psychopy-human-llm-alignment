        <Param val="False" valType="bool" updates="constant" name="syncScreenRefresh"/>
      </KeyboardComponent>
      <CodeComponent name="elTrial" plugin="None">
        <Param val="# This variables helps to ensure we don't schedule multiple method calls&amp;#10;# of eyelink_onFlip_MarkEvents for each retrace&amp;#10;eyelinkThisFrameCallOnFlipScheduled = False&amp;#10;&amp;#10;&amp;#10;# This method gets scheduled to be called on each flip/retrace in the &amp;#10;# Each Frame tab.  This method  checks for component onsets and sends event &amp;#10;# marking messgaes and Data Viewe integration messages when these component onsets are detected&amp;#10;def eyelink_onFlip_MarkEvents(fixation,image,globalClock,scn_width,scn_height):&amp;#10;    global eyelinkThisFrameCallOnFlipScheduled, eyelinkLastFlipTime&amp;#10;    interestAreaMargins = 0&amp;#10;        &amp;#10;    currentFlipTime = globalClock.getTime()&amp;#10;    &amp;#10;    #Check whether it is the first retrace of the fixation presentation&amp;#10;    if fixation.tStartRefresh is not None and not fixation.elOnsetDetected:&amp;#10;    &amp;#10;        # Send an event-marking message for the onset of the image component&amp;#10;        # The message includes a temporal offset based on the current time minus&amp;#10;        # the onset of the stimulus.  Data Viewer will automatically subtract&amp;#10;        # this offset from the message time to position the message at the &amp;#10;        # appropriate time point&amp;#10;        offset = int(round((globalClock.getTime()-fixation.tStartRefresh)*1000))&amp;#10;        el_tracker.sendMessage('%i FIXATION_ONSET' % offset)&amp;#10;    &amp;#10;        # send some Data Viewer drawing commands so that you can see a representation&amp;#10;        # of the fixation cross in Data Viewer's various visualizations&amp;#10;        # For more information on this, see section &quot;Protocol for EyeLink Data to &amp;#10;        # Viewer Integration&quot; section of the Data Viewer User Manual (Help -&gt; Contents)&amp;#10;        el_tracker.sendMessage('%i !V CLEAR 128 128 128' % offset)&amp;#10;        el_tracker.sendMessage('%i !V DRAWLINE 255 255 255 %i %i %i %i' % \&amp;#10;            (offset,scn_width/2 - 25,scn_height/2,scn_width/2 + 25,scn_height/2))  &amp;#10;        el_tracker.sendMessage('%i !V DRAWLINE 255 255 255 %i %i %i %i' % \&amp;#10;            (offset,scn_width/2,scn_height/2 - 25,scn_width/2,scn_height/2 + 25))&amp;#10;            &amp;#10;        # send a Data Viewer interest area command to create an interest area&amp;#10;        # that can be used during analysis&amp;#10;        # For more information on this, see section &quot;Protocol for EyeLink Data to &amp;#10;        # Viewer Integration&quot; section of the Data Viewer User Manual (Help -&gt; Contents)&amp;#10;        el_tracker.sendMessage('%i !V IAREA RECTANGLE 1 %i %i %i %i fixation_cross' % (offset,\&amp;#10;            fixation.elPos[0]-(fixation.elSize[0]/2+interestAreaMargins),\&amp;#10;            fixation.elPos[1]-(fixation.elSize[1]/2+interestAreaMargins),\&amp;#10;            fixation.elPos[0]+(fixation.elSize[0]/2+interestAreaMargins),\&amp;#10;            fixation.elPos[1]+(fixation.elSize[1]/2+interestAreaMargins)))&amp;#10;            &amp;#10;        # log the fixation onset time (in Display PC time) as a Trial Variable&amp;#10;        fixationTime = fixation.tStartRefresh*1000&amp;#10;        el_tracker.sendMessage('!V TRIAL_VAR fixationTime %i' % fixationTime)&amp;#10;        &amp;#10;        # set this property of the component to True to ensure we don't write &amp;#10;        # the event message draw command messages again on future retraces&amp;#10;        fixation.elOnsetDetected = True&amp;#10;        &amp;#10;    &amp;#10;    #  Check whether it is the first retrace of the image presentation&amp;#10;    if image.tStartRefresh is not None and not image.elOnsetDetected:&amp;#10;        &amp;#10;        # Send an event-marking message for the onset of the image component&amp;#10;        # The message includes a temporal offset based on the current time minus&amp;#10;        # the onset of the stimulus.  Data Viewer will automatically subtract&amp;#10;        # this offset from the message time to position the message at the &amp;#10;        # appropriate time point&amp;#10;        offset = int(round((globalClock.getTime()-image.tStartRefresh)*1000))&amp;#10;        el_tracker.sendMessage('%i IMAGE_ONSET' % offset)&amp;#10;            &amp;#10;        # send some Data Viewer drawing commands so that you can see the trial image&amp;#10;        # in Data Viewer's various visualizations&amp;#10;        # For more information on this, see section &quot;Protocol for EyeLink Data to &amp;#10;        # Viewer Integration&quot; section of the Data Viewer User Manual (Help -&gt; Contents)&amp;#10;        el_tracker.sendMessage('%i !V CLEAR 128 128 128' % offset)&amp;#10;        el_tracker.sendMessage('%i !V IMGLOAD CENTER ../../%s %i %i' % \&amp;#10;            (offset,targetImage+&quot;target.png&quot;,image.elPos[0],image.elPos[1]))&amp;#10;        &amp;#10;        # send a Data Viewer interest area command to create an interest area&amp;#10;        # that can be used during analysis&amp;#10;        # For more information on this, see section &quot;Protocol for EyeLink Data to &amp;#10;        # Viewer Integration&quot; section of the Data Viewer User Manual (Help -&gt; Contents) &amp;#10;        el_tracker.sendMessage('%i !V IAREA RECTANGLE 2 %i %i %i %i image' % (offset, \&amp;#10;            image.elPos[0]-(image.elSize[0]/2+interestAreaMargins),\&amp;#10;            image.elPos[1]-(image.elSize[1]/2+interestAreaMargins),\&amp;#10;            image.elPos[0]+(image.elSize[0]/2+interestAreaMargins),\&amp;#10;            image.elPos[1]+(image.elSize[1]/2+interestAreaMargins)))&amp;#10;         &amp;#10;        # log the image onset time (in Display PC time) as a Trial Variable  &amp;#10;        el_tracker.sendMessage('!V TRIAL_VAR IMAGE_ONSET_TIME %i' % \&amp;#10;            (image.tStartRefresh*1000))&amp;#10;            &amp;#10;        # set this property of the component to True to ensure we don't write &amp;#10;        # the event message draw command messages again on future retraces&amp;#10;        image.elOnsetDetected = True&amp;#10;    &amp;#10;    eyelinkThisFrameCallOnFlipScheduled = False&amp;#10;&amp;#10;&amp;#10;              &amp;#10;# This method takes the position of a component and the window size as input&amp;#10;# and returns the EyeLink position &amp;#10;# EyeLink position is in pixels, where (0,0) is the top-left corner&amp;#10;# of the screen, and position increases in value as gaze moves right and down&amp;#10;# e.g., bottom right of 1920 x 1080 monitor is (1919,1079)&amp;#10;def eyelink_pos(pos,winSize):&amp;#10;    screenUnitType = 'pix'&amp;#10;    scn_width,scn_height = winSize&amp;#10;    if screenUnitType == 'pix':&amp;#10;        elPos = [pos[0] + scn_width/2,scn_height/2 - pos[1]]&amp;#10;    elif screenUnitType == 'height':&amp;#10;        elPos = [scn_width/2 + pos[0] * scn_height,scn_height/2 + pos[1] * scn_height]&amp;#10;    elif screenUnitType == &quot;norm&quot;:&amp;#10;        elPos = [(scn_width/2 * pos[0]) + scn_width/2,scn_height/2 + pos[1] * scn_height]&amp;#10;    else:&amp;#10;        print(&quot;ERROR:  Only pixel, height, and norm units supported for conversion to EyeLink position units&quot;)&amp;#10;    return [int(round(elPos[0])),int(round(elPos[1]))]&amp;#10;&amp;#10;# this method converts PsychoPy size values to EyeLink size values&amp;#10;# EyeLink size values are in pixels&amp;#10;def eyelink_size(size,winSize):&amp;#10;    screenUnitType = 'pix'&amp;#10;    scn_width,scn_height = winSize&amp;#10;    if len(size) == 1:&amp;#10;        size = [size[0],size[0]]&amp;#10;    if screenUnitType == 'pix':&amp;#10;        elSize = [size[0],size[1]]&amp;#10;    elif screenUnitType == 'height':&amp;#10;        elSize = [int(round(scn_height*size[0])),int(round(scn_height*size[1]))]&amp;#10;    elif screenUnitType == &quot;norm&quot;:&amp;#10;        elSize = [size[0]/2 * scn_width,size[1]/2 * scn_height]&amp;#10;    else:&amp;#10;        print(&quot;ERROR:  Only pixel, height, and norm units supported for conversion to EyeLink position units&quot;)&amp;#10;    return [int(round(elSize[0])),int(round(elSize[1]))]" valType="extendedCode" updates="constant" name="Before Experiment"/>
        <Param val="/* Syntax Error: Fix Python code */" valType="extendedCode" updates="constant" name="Before JS Experiment"/>
        <Param val="# This Begin Experiment tab of the elTrial component just initializes&amp;#10;# a trial counter variable at the beginning of the experiment&amp;#10;&amp;#10;trial_index = 1&amp;#10;&amp;#10;global eyelinkThisFrameCallOnFlipScheduled" valType="extendedCode" updates="constant" name="Begin Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="# This Begin Routine tab of the elTrial component resets some &amp;#10;# variables that are used to keep track of whether certain trial events have&amp;#10;# happened and sends trial variable messages to the EDF to mark condition&amp;#10;# information&amp;#10;&amp;#10;# these variables keep track of whether the fixation presentation, image &amp;#10;# presentation, and trial response have occured yet (0 = no, 1 = yes).&amp;#10;# They later help us to ensure that each event marking message only gets&amp;#10;# sent once, at the time of each event&amp;#10;fixation.elOnsetDetected = False&amp;#10;image.elOnsetDetected = False&amp;#10;&amp;#10;# Set elPos and elSize properties for the components by calling&amp;#10;# methods that convert from PsychoPy units to EyeLink units&amp;#10;image.elPos = eyelink_pos(image.pos,[scn_width,scn_height])&amp;#10;image.elSize = eyelink_size(image.size,[scn_width,scn_height])&amp;#10;fixation.elPos = eyelink_pos(fixation.pos,[scn_width,scn_height])&amp;#10;fixation.elSize = eyelink_size(fixation.size,[scn_width,scn_height])&amp;#10;&amp;#10;# create a keyboard instance and reinitialize a kePressNameList, which &amp;#10;# will store list of key names currently being pressed (to allow Ctrl-C abort)&amp;#10;kb = keyboard.Keyboard()&amp;#10;keyPressNameList = list()&amp;#10;&amp;#10;# record trial variables to the EDF data file, for details, see Data&amp;#10;# Viewer User Manual, &quot;Protocol for EyeLink Data to Viewer Integration&quot;&amp;#10;el_tracker.sendMessage('!V TRIAL_VAR trials %s' % trials.thisN)&amp;#10;el_tracker.sendMessage('!V TRIAL_VAR iterations %s' % iterations.thisN)&amp;#10;el_tracker.sendMessage('!V TRIAL_VAR image %s' % targetImage)&amp;#10;el_tracker.sendMessage('!V TRIAL_VAR Unix Time %s' % time.time())&amp;#10;# if sending many messages in a row, add a 1 msec pause between after &amp;#10;# every 5 messages or so&amp;#10;&amp;#10;&amp;#10;#routineTimer.reset()&amp;#10;" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="Py" valType="str" updates="None" name="Code Type"/>
        <Param val="" valType="extendedCode" updates="constant" name="Each Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="Each JS Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Routine"/>
        <Param val="# This End Routine tab of the elTrial component handles the marking&amp;#10;# of response events via messages to the EDF and sends additional messages&amp;#10;# to log data about the response as trial variables.  It also marks the end&amp;#10;# of the trial&amp;#10;&amp;#10;# if a key was presssed, calculate the difference between the current time &amp;#10;# and the time of the key press onset. &amp;#10;# This offset value will be sent at the beginning of the message&amp;#10;# and will automatically be subtracted by Data Viewer from the timestamp&amp;#10;# of the message to position the message at the correct point in time&amp;#10;# then send a message marking the event&amp;#10;if not isinstance(resp.rt,list):&amp;#10;    offsetValue = int(round((globalClock.getTime() - \&amp;#10;        (resp.tStartRefresh + resp.rt))*1000))&amp;#10;    el_tracker.sendMessage('%i KEY_PRESSED' % offsetValue)&amp;#10;    el_tracker.sendMessage('!V TRIAL_VAR accuracy %i' % resp.corr)&amp;#10;    el_tracker.sendMessage('!V TRIAL_VAR keyPressed %s' % resp.keys)&amp;#10;    # if sending many messages in a row, add a 1 msec pause between after &amp;#10;    # every 5 messages or so&amp;#10;    time.sleep(0.001)&amp;#10;    el_tracker.sendMessage('!V TRIAL_VAR RT %i' % int(round(resp.rt * 1000)))" valType="extendedCode" updates="constant" name="End Routine"/>
        <Param val="False" valType="bool" updates="None" name="disabled"/>
        <Param val="elTrial" valType="code" updates="None" name="name"/>
      </CodeComponent>
