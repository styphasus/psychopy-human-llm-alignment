        <Param val="import * as time from 'time';&amp;#10;import * as psychopy.visual from 'psychopy/visual';&amp;#10;psychoJS.experiment.addData(&quot;break.stopped_Unix&quot;, time.time());&amp;#10;window = new psychopy.visual.Window();&amp;#10;window.saveMovieFrames(&quot;frames.png&quot;);&amp;#10;" valType="extendedCode" updates="constant" name="End JS Routine"/>
        <Param val="import time&amp;#10;import psychopy.visual&amp;#10;thisExp.addData(&quot;break.stopped_Unix&quot;, time.time())&amp;#10;window = psychopy.visual.Window()&amp;#10;window.saveMovieFrames('frames.png')" valType="extendedCode" updates="constant" name="End Routine"/>
